
# Configuration de l'application TAXRECLAIMAI

# Base de données
# Pour le développement: sqlite:///./data/taxreclaim.db
# Pour Back4App: postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///./data/taxreclaim.db

# Clés secrètes JWT
SECRET_KEY=votre-secret-key-a-changer-en-production
JWT_SECRET_KEY=votre-secret-jwt-a-changer
JWT_ALGORITHM=HS256

# Configuration des tokens JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Configuration de l'authentification
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Configuration du 2FA
2FA_ISSUER_NAME=TAXRECLAIMAI
2FA_DIGITS=6
2FA_BACKUP_CODES_COUNT=10

# Configuration de l'application
ENVIRONMENT=development
DEBUG=True

# Configuration CORS
ALLOWED_ORIGINS=*

# Configuration du rate limiting
MAX_REQUESTS_PER_MINUTE=100
MAX_LOGIN_ATTEMPTS_PER_5MINUTES=5

# Configuration de l'OCR
TESSERACT_PATH=/usr/bin/tesseract

# Configuration des fichiers
UPLOAD_DIR=./uploads
PROCESSED_DIR=./processed
FORMS_DIR=./forms
TEMP_DIR=./temp
DATA_DIR=./data

# Configuration du traitement par lots
MAX_BATCH_SIZE=120
BATCH_PROCESSING_TIMEOUT_SECONDS=300

# Configuration de la récupération TVA
DEFAULT_VAT_RECOVERY_RATE=0.8
MIN_VAT_RECOVERY_AMOUNT=50.0

# Configuration des formulaires
FORM_GENERATION_TIMEOUT_SECONDS=60
MAX_FORMS_PER_ZIP=50

# Configuration des notifications
NOTIFICATION_RETENTION_DAYS=90
MAX_NOTIFICATIONS_PER_USER=1000

# Configuration du workflow
APPROVAL_TIMEOUT_HOURS=72
ESCALATION_TIMEOUT_HOURS=168
